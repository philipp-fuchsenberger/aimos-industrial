# AIMOS Configuration
# Copy to .env and fill in your values

# ── Database ──
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=aimos
PG_USER=aimos_user
PG_PASSWORD=your_secure_password

# ── LLM (Ollama) ──
LLM_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=qwen2.5:14b
LLM_KEEP_ALIVE=30m
LLM_TEMPERATURE=0.7
LLM_NUM_CTX=14336

# ── Dashboard ──
AIMOS_DASHBOARD_PASSWORD=change_me

# ── Output Firewall ──
CLEAN_CJK=true
